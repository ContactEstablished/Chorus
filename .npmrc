# Native modules must match Electron's ABI, not Node's. prebuild-install-based
# deps (better-sqlite3) read these to download the electron prebuild instead of
# the node one. node-pty is unaffected: its N-API prebuilds ship in-package.
# Keep `target` in sync with the electron version in package.json.
# NOTE: better-sqlite3 12.11.1 has no electron-v148 prebuild on npm, so a fresh
# install falls back to a source build, and MSVC 17.14 ICEs (C1001) on sqlite3.c
# at default optimization. If that happens run: npm run rebuild:better-sqlite3
# (drop this workaround once better-sqlite3 >= 12.11.2 is published to npm).
runtime=electron
target=43.1.1
disturl=https://electronjs.org/headers
